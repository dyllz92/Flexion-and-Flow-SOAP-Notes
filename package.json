{
  "name": "soap-note-generator",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node -e \"const fs=require('fs');const r=JSON.parse(fs.readFileSync('dist/_routes.json'));r.exclude=['/static/*','/*.png','/*.jpg','/*.ico','/*.svg','/*.webp','/*.gif'];fs.writeFileSync('dist/_routes.json',JSON.stringify(r));console.log('_routes.json patched')\"",
    "preview": "wrangler pages dev dist --ip 0.0.0.0 --port 3000",
    "deploy": "npm run build && wrangler pages deploy dist",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "dev:sandbox": "wrangler pages dev dist --ip 0.0.0.0 --port 3000"
  },
  "dependencies": {
    "hono": "^4.12.3"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
